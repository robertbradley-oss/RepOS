# RepOS local/demo runtime settings.
# The server does not auto-load this file; set these in your shell or deployment environment.

# Local default: 127.0.0.1. Use 0.0.0.0 only when a Node hosting platform requires it.
HOST=127.0.0.1
PORT=4173

# Default JSON persistence and upload locations. Keep these out of Git.
TESSARIO_DATA_FILE=.data/tessario-state.json
TESSARIO_UPLOAD_DIR=.uploads
TESSARIO_MAX_UPLOAD_BYTES=20971520

# Development auto-authenticates the seeded admin user. Use strict for auth checks.
TESSARIO_AUTH_MODE=development
TESSARIO_DISABLE_DEV_LOGIN=0
TESSARIO_SESSION_DAYS=7

# Hosted/production demos should disable automatic admin fallback and dev login.
# Set REPOS_DEMO_PASSWORD to a private value before exposing the demo publicly.
# TESSARIO_AUTH_MODE=strict
# TESSARIO_DISABLE_DEV_LOGIN=1
# TESSARIO_SESSION_DAYS=7
# REPOS_DEMO_PASSWORD=replace-with-a-private-demo-password
# REPOS_SECURE_COOKIES=1

# Optional Postgres mode. Leave unset to use JSON-file persistence.
# DATABASE_URL=postgres://user:password@localhost:5432/tessario
# PGSSLMODE=require
# TESSARIO_AUTO_MIGRATE=1
